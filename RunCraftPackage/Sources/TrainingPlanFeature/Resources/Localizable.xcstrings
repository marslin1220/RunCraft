    "Use the stepper to adjust. Changes only commit when you tap Save.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ステッパーで調整してください。「保存」をタップしたときだけ変更が反映されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스텝퍼로 조정하세요. \"저장\"을 눌러야 변경 사항이 적용됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用步进器调整。按下「保存」后才会生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用步進器調整。按下「儲存」後才會生效。"
          }
