    },
    "RunCraft uses your VDOT to set your five training pace zones — Easy, Marathon, Threshold, Interval, and Repetition — so every session targets the right physiological adaptation." : {
      "extractionState" : "manual",
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RunCraft 用你的 VDOT 設定五個訓練配速區間 — 輕鬆、馬拉松、乳酸閾值、間歇、反覆衝刺 — 讓每次訓練都打到對的生理適應。"
          }
        }
      }
    },
    "Save" : {
      "extractionState" : "manual",
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "儲存"
          }
        }
      }
    },
    "Scans your HealthKit running history for a best 5K, 10K or half marathon time." : {
      "extractionState" : "manual",
      "localizations" : {
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "掃描你 HealthKit 中的跑步紀錄，找出最佳的 5K、10K 或半馬成績。"
          }
        }
      }
    },
