    "HR recovery · 90 days": {
      "extractionState": "manual",
      "localizations": {
        "ja": { "stringUnit": { "state": "translated", "value": "HR 回復 · 90 日間" } },
        "ko": { "stringUnit": { "state": "translated", "value": "HR 회복 · 90일" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "心率恢复 · 90 天" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "心率恢復 · 90 天" } }
      }
    },
    "HR recovery is recorded by Apple Watch at the end of each workout. Complete a few outdoor runs to see your trend.": {
      "extractionState": "manual",
      "localizations": {
        "ja": { "stringUnit": { "state": "translated", "value": "HR 回復はワークアウト終了時に Apple Watch が記録します。屋外ランを数回行うとトレンドが表示されます。" } },
        "ko": { "stringUnit": { "state": "translated", "value": "HR 회복은 Apple Watch가 각 운동이 끝날 때 기록합니다. 야외 러닝을 몇 번 완료하면 추이를 볼 수 있습니다." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "心率恢复由 Apple Watch 在每次锻炼结束时记录。完成几次户外跑步即可看到趋势。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "心率恢復由 Apple Watch 在每次運動結束時記錄。完成幾次戶外跑步即可看到趨勢。" } }
      }
    },
    "HRV readings appear here after Apple Watch records overnight SDNN data. Wear your Watch to sleep for a few nights.": {
      "extractionState": "manual",
      "localizations": {
        "ja": { "stringUnit": { "state": "translated", "value": "Apple Watch が睡眠中の SDNN データを記録すると、HRV 測定値がここに表示されます。数晩 Watch を着けて寝てください。" } },
        "ko": { "stringUnit": { "state": "translated", "value": "Apple Watch가 야간 SDNN 데이터를 기록하면 HRV 수치가 여기에 표시됩니다. 며칠 밤 Watch를 착용하고 주무세요." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "Apple Watch 记录到夜间 SDNN 数据后，HRV 读数将显示在这里。请佩戴 Watch 入睡几个晚上。" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "Apple Watch 記錄到夜間 SDNN 資料後，HRV 讀數將顯示在這裡。請佩戴 Watch 入睡幾個晚上。" } }
      }
    },
