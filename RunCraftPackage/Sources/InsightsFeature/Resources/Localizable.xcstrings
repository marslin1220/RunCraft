    "Need both VDOT history and VO₂max samples to compute the gap." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "差分を計算するには、VDOT 履歴と VO₂max データの両方が必要です。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "차이를 계산하려면 VDOT 기록과 VO₂max 샘플이 모두 필요합니다." } },
