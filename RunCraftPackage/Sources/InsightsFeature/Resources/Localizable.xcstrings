    "Not enough VDOT history yet — log a race or finish a hard session to build your trend.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "VDOTの履歴がまだ不足しています。レースを記録するか、ハードなセッションを完了してトレンドを構築してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "VDOT 기록이 아직 부족합니다. 레이스를 기록하거나 힘든 세션을 완료하여 추세를 구축하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "VDOT 历史记录不足——记录一场比赛或完成一次高强度训练以建立趋势。"
          }
        },
        "zh-Hant": {
