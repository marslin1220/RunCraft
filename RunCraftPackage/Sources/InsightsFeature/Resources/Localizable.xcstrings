      }
    },
    "Not enough history yet — log a race or finish a few hard sessions.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ十分な履歴がありません — レースを記録するか、ハードなセッションをこなしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 기록이 부족합니다 — 레이스를 기록하거나 강도 높은 훈련을 완수하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有足够的历史数据 — 记录一场比赛，或完成几次高强度训练。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "還沒有足夠的歷史資料 — 記錄一場比賽，或完成幾次高強度訓練。"
          }
        }
      }
    },
