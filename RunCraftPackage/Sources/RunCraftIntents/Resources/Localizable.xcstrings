          }
        }
      }
    },
    "Set up a race goal in RunCraft to apply this to your plan.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "RunCraft でレース目標を設定すると、この変更がプランに適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "RunCraft에서 레이스 목표를 설정하면 이 변경이 계획에 적용됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 RunCraft 设定比赛目标，这个变更才会应用到你的计划。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 RunCraft 設定比賽目標，這個變更才會套用到你的計畫。"
          }
        }
      }
    },
