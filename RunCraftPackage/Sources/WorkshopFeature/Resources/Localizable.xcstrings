    "Start from a template or build one from scratch.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テンプレートから始めるか、ゼロから作成しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
