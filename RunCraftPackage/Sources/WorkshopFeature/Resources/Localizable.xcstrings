    "Tap a zone to fill from your current VDOT (%lld).": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゾーンをタップすると現在の VDOT（%lld）から自動入力されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "존을 누르면 현재 VDOT(%lld)으로 자동 입력됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点选区间，以当前的 VDOT（%lld）自动填入。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點選區間，以目前的 VDOT（%lld）自動填入。"
          }
        }
      }
    },
    "Tap to copy an existing step into this repeat. The copy is independent — editing it doesn't change the original.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タップして既存のステップをこのリピートにコピー。コピーは独立しており、元のステップは変わりません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기존 스텝을 이 반복에 복사하려면 누르세요. 사본은 원본과 독립적입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点一下把现有步骤复制进这个重复组。副本与原版独立，编辑不会互相影响。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點一下把現有步驟複製進這個重複組。副本與原版獨立，編輯不會互相影響。"
          }
        }
      }
    },
    "Tap ⋯ to add a Step or a Repeat group.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "⋯ をタップしてステップやリピートを追加。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⋯을 눌러 스텝이나 반복을 추가하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点 ⋯ 来新增步骤或重复组。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點 ⋯ 來新增步驟或重複組。"
          }
        }
      }
    },
