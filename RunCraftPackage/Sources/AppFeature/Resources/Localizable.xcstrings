    "One tap to your wrist" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ワンタップで手首へ" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "원 탭으로 손목까지" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "一键直达手表" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "一鍵直達手錶" } }
      }
    },
    "Periodised plans, real Apple Watch dispatch, and Siri-driven control — everything a serious runner needs in one app." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ピリオダイズされたプラン、Apple Watch への直接ディスパッチ、Siri 制御 — シリアスランナーに必要なものをひとつの App に。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "주기화된 계획, 실제 Apple Watch 디스패치, Siri 음성 제어 — 진지한 러너에게 필요한 모든 것이 하나의 앱에." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "周期化计划、Apple Watch 派送、Siri 语音控制 — 严肃跑者需要的全在一个 App。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "週期化計畫、Apple Watch 派送、Siri 語音控制 — 嚴肅跑者需要的全在一個 App。" } }
      }
    },
    "Send any workout to your paired Apple Watch with a single button. Pace alerts run on-wrist — no menu hunting mid-stride." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ペアリング済みの Apple Watch にワークアウトをワンボタンで送信。ペースアラートは手首で鳴る — 走行中にメニューを探す必要はありません。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "페어링된 Apple Watch에 운동을 한 번의 버튼으로 전송. 페이스 알림은 손목에서 — 달리는 중 메뉴를 뒤질 필요 없습니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "一键把任何训练传到配对的 Apple Watch。配速警示在手腕上即时提醒 — 跑步中不必滑选单。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "一鍵把任何訓練傳到配對的 Apple Watch。配速警示在手腕上即時提醒 — 跑步中不必滑選單。" } }
      }
    },
