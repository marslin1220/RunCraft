    "\"What's today's training?\" · \"Start Yasso 800.\" · \"Set my VDOT to 52.\" RunCraft answers, dispatches, and saves." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "「今日のトレーニングは？」「Yasso 800 を開始」「VDOT を 52 に設定」— RunCraft が回答し、送信し、保存します。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "\"오늘의 훈련은?\" · \"Yasso 800 시작\" · \"VDOT을 52로 설정\" — RunCraft가 답하고, 전송하고, 저장합니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "「今天的训练是什么？」「开始 Yasso 800」「把 VDOT 设为 52」— RunCraft 回答、派送、储存。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "「今天的訓練是什麼？」「開始 Yasso 800」「把 VDOT 設為 52」— RunCraft 回答、派送、儲存。" } }
      }
    },
