        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "以 VDOT 为核心" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "以 VDOT 為核心" } }
      }
    },
    "Enter a race time — or let HealthKit pull your best — and RunCraft derives your five training pace zones from the Daniels formula." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "レースタイムを入力するか、HealthKit からベストを取得すると、RunCraft が Daniels 公式から 5 つのトレーニングペースを算出します。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "레이스 기록을 입력하거나 HealthKit에서 최고 기록을 가져오면 RunCraft가 Daniels 공식으로 5가지 훈련 페이스를 산출합니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "输入近期比赛成绩，或让 HealthKit 自动找出最佳值，RunCraft 用 Daniels 公式推导你的五个训练配速区间。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "輸入近期比賽成績，或讓 HealthKit 自動找出最佳值，RunCraft 用 Daniels 公式推導你的五個訓練配速區間。" } }
      }
    },
    "Forty years of Jack Daniels' coaching" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "Jack Daniels の 40 年のコーチング" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "Jack Daniels의 40년 코칭" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Jack Daniels 四十年教练心法" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "Jack Daniels 四十年教練心法" } }
      }
    },
