        "ko" : { "stringUnit" : { "state" : "translated", "value" : "RunCraft을 열어 세션을 확인하고 Apple Watch로 전송하세요." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "打开 RunCraft 查看你的训练，并派送到 Apple Watch。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "打開 RunCraft 查看你的訓練，並派送到 Apple Watch。" } }
