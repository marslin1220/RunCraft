    "Daily nudge at the time you pick. Tap to open RunCraft and dispatch today's session to Apple Watch." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "指定した時刻に毎日リマインド。タップで RunCraft を開いて今日のセッションを Apple Watch に送信できます。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "지정한 시간에 매일 알림. 탭해서 RunCraft을 열고 오늘 세션을 Apple Watch로 보낼 수 있습니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "在你选定的时间每天提醒。点一下打开 RunCraft，把今天的训练派送到 Apple Watch。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "在你選定的時間每天提醒。點一下打開 RunCraft，把今天的訓練派送到 Apple Watch。" } }
      }
    },
