    "weather.tip.cloudy" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cloudy today — 15 minutes of stretching will do wonders."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "曇り空。15分のストレッチで筋肉をリフレッシュしましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "흐린 날씨. 15분 스트레칭으로 근육을 풀어보세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天多云，做个 15 分钟拉伸，让肌肉好好放松。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天多雲，做個 15 分鐘拉伸，讓肌肉好好放鬆。"
          }
        }
      }
    },
    "weather.tip.foggy" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Foggy today — take it easy indoors and let your body repair."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今日は霧があります。屋外の激しい運動は避けて室内で休養を。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "안개 낀 날씨. 실내에서 가볍게 쉬며 회복하는 것이 좋아요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天有雾，避免户外剧烈活动，在室内轻松恢复最安心。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天有霧，避免戶外劇烈活動，在室內輕鬆恢復最安心。"
          }
        }
      }
    },
    "weather.tip.partlyCloudy" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pleasant clouds and comfortable temperature — great for a stroll."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過ごしやすい天気。軽く外を歩いて体をほぐしましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "쾌적한 날씨예요. 가볍게 걸어 몸을 풀어보세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "云量适中、气温舒适，很适合出门轻松散步。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "雲量適中、氣溫舒適，很適合出門輕鬆散步。"
          }
        }
      }
    },
    "weather.tip.rainy" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rainy day — ideal time for indoor core work or yoga."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "雨の日は室内でコアトレーニングやヨガをしましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비 오는 날, 실내 코어 운동이나 요가하기 좋아요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下雨天，正是在家做核心训练或瑜伽的好时机。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下雨天，正是在家做核心訓練或瑜珈的好時機。"
          }
        }
      }
    },
    "weather.tip.snow" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snow day — stay warm and keep any movement gentle indoors."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "雪の日。暖かくして室内で軽く体を動かしましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "눈 오는 날, 따뜻하게 있으며 실내에서 가볍게 움직여요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天下雪，注意保暖，在室内做轻度活动即可。"
