    "rest.recovery.fallback" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recharge and let your body repair — great workout ahead."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "しっかり回復して、次のトレーニングに備えましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "충분히 쉬고 다음 훈련을 준비하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "好好充电，让身体修复，下次训练会更好。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "好好充電，讓身體修復，下次訓練會更好。"
          }
        }
      }
    },
