  "strings": {
    "No plan yet": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プラン未設定"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계획 없음"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尚无计划"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "尚無計畫"
          }
        }
      }
    },
    "No run scheduled today": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日のランは予定されていません"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘은 예정된 러닝이 없습니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今天没有安排跑步"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "今天沒有安排跑步"
          }
        }
      }
    },
    "Open RunCraft to set up a plan": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "RunCraft を開いてプランを設定"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "RunCraft을 열어 계획을 설정하세요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开 RunCraft 设定训练计划"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "打開 RunCraft 設定訓練計畫"
          }
        }
      }
    },
    "Rest day": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "休養日"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "휴식일"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "休息日"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "休息日"
          }
        }
      }
    },
    "See and start today's planned training session.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日の予定セッションを確認し、開始できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘 예정된 훈련 세션을 확인하고 시작하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看并开始今天计划的训练课程。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "查看並開始今天計畫的訓練課程。"
          }
        }
      }
    },
