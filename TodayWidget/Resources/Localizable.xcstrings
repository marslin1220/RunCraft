    },
    "weather.tip.stormy" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Storm outside — staying home and resting well is the smartest move."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "嵐の日は家でゆっくり休むのが最高の回復法です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "폭풍우 날씨엔 집에서 충분히 쉬는 것이 최선이에요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "风雨交加，待在家好好休息就是最棒的恢复方式。"
